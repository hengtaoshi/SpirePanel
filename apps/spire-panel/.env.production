VITE_BASE=/

# Supabase 配置（部署时填入生产环境值）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 接口地址
VITE_GLOB_API_URL=/api

# Lite/Pro 开关
VITE_PRO_ENABLED=false

# 是否开启压缩
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
