# 端口号
VITE_PORT=5888

VITE_BASE=/

# Supabase 配置
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# 接口地址（通过 Supabase Edge Functions）
VITE_GLOB_API_URL=/api

# 是否开启 Nitro Mock服务
VITE_NITRO_MOCK=false

# Lite/Pro 开关
VITE_PRO_ENABLED=false

# 是否打开 devtools
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
